rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'displayName', 'level', 'xp', 'criptoBlue', 'currentClassId', 'isOnline']) &&
             isValidString('displayName', 1, 50) &&
             request.resource.data.level is number && request.resource.data.level >= 1 &&
             request.resource.data.xp is number && request.resource.data.xp >= 0 &&
             request.resource.data.criptoBlue is number && request.resource.data.criptoBlue >= 0 &&
             request.resource.data.isOnline is bool;
    }

    function isValidMessage() {
      return hasRequiredFields(['text', 'authorUid', 'authorName', 'type', 'timestamp']) &&
             isValidString('text', 1, 1000) &&
             isValidString('authorName', 1, 50) &&
             request.resource.data.authorUid == request.auth.uid &&
             request.resource.data.type in ['user', 'system', 'combat', 'gacha'] &&
             request.resource.data.timestamp is string;
    }

    function isValidPvPBattle() {
      return hasRequiredFields(['challengerUid', 'defenderUid', 'status', 'createdAt']) &&
             request.resource.data.status in ['pending', 'accepted', 'declined', 'finished'] &&
             request.resource.data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for ranking, online list, pvp)
      allow read: if isAuthenticated();
      
      // Users can only create and update their own profiles
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isAuthenticated() && isValidUser() && uidNotModified();
      allow delete: if false; // No deletion
    }

    match /messages/{messageId} {
      // Anyone authenticated can read messages
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create a message, but they must be the author
      allow create: if isAuthenticated() && isValidMessage();
      
      allow update, delete: if false; // Messages cannot be edited or deleted
    }

    match /pvp_battles/{battleId} {
      // Anyone authenticated can read battles
      allow read: if isAuthenticated();
      
      // Challenger can create a battle
      allow create: if isAuthenticated() && isValidPvPBattle() && request.resource.data.challengerUid == request.auth.uid;
      
      // Both challenger and defender can update the battle state
      allow update: if isAuthenticated() && isValidPvPBattle() && 
                    (resource.data.challengerUid == request.auth.uid || resource.data.defenderUid == request.auth.uid);
      
      allow delete: if false;
    }
  }
}
